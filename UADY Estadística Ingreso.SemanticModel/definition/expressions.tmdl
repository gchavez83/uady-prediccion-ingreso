expression FxCalendar = ```
		let fnDateTable = (FechaInicio as date, FechaFinal as date, FYStartMonth as number) as table =>
		  let
		    DayCount = Duration.Days(Duration.From(FechaFinal - FechaInicio)),
		    Source = List.Dates(FechaInicio,DayCount,#duration(1,0,0,0)),
		    TableFromList = Table.FromList(Source, Splitter.SplitByNothing()),   
		    ChangedType = Table.TransformColumnTypes(TableFromList,{{"Column1", type date}}),
		    RenamedColumns = Table.RenameColumns(ChangedType,{{"Column1", "IdFecha"}}),
		    InsertYear = Table.AddColumn(RenamedColumns, "Año", each Date.Year([IdFecha]),type text),
		    InsertYearNumber = Table.AddColumn(RenamedColumns, "NumeroAño", each Date.Year([IdFecha])),
		    InsertQuarter = Table.AddColumn(InsertYear, "TrimestreAño", each Date.QuarterOfYear([IdFecha])),
		    InsertMonth = Table.AddColumn(InsertQuarter, "MesAño", each Date.Month([IdFecha]), type text),
		    InsertDay = Table.AddColumn(InsertMonth, "DiaMes", each Date.Day([IdFecha])),
		    InsertDayInt = Table.AddColumn(InsertDay, "FechaEntera", each [Año] * 10000 + [MesAño] * 100 + [DiaMes]),
		    InsertMonthName = Table.AddColumn(InsertDayInt, "NombreMes", each Date.ToText([IdFecha], "MMMM"), type text),
		    InsertCalendarMonth = Table.AddColumn(InsertMonthName, "Mes&Año", each (try(Text.Range([NombreMes],0,3)) otherwise [NombreMes]) & " " & Number.ToText([Año])),
		    InsertCalendarQtr = Table.AddColumn(InsertCalendarMonth, "Trim&Año", each "Q" & Number.ToText([TrimestreAño]) & " " & Number.ToText([Año])),
		    InsertDayWeek = Table.AddColumn(InsertCalendarQtr, "DiaNumeroSemana", each Date.DayOfWeek([IdFecha])),
		    InsertDayName = Table.AddColumn(InsertDayWeek, "DiaNombreSemana", each Date.ToText([IdFecha], "dddd"), type text),
		    InsertWeekEnding = Table.AddColumn(InsertDayName, "FinSemana", each Date.EndOfWeek([IdFecha]), type date),
		    InsertWeekNumber= Table.AddColumn(InsertWeekEnding, "NumeroSemana", each Date.WeekOfYear([IdFecha])),
		    InsertMonthnYear = Table.AddColumn(InsertWeekNumber,"Año&Mes", each [Año] * 10000 + [MesAño] * 100),
		    InsertQuarternYear = Table.AddColumn(InsertMonthnYear,"Año&Trim", each [Año] * 10000 + [TrimestreAño] * 100),
		    ChangedType1 = Table.TransformColumnTypes(InsertQuarternYear,{{"Año&Trim", Int64.Type},{"NumeroSemana", Int64.Type},{"Año", type text},{"Año&Mes", Int64.Type}, {"FechaEntera", Int64.Type}, {"DiaMes", Int64.Type}, {"MesAño", Int64.Type}, {"TrimestreAño", Int64.Type}, {"Mes&Año", type text}, {"Trim&Año", type text}, {"DiaNumeroSemana", Int64.Type}}),
		    InsertShortYear = Table.AddColumn(ChangedType1, "AñoCorto", each Text.End(Text.From([Año]), 2), type text),
		    AddFY = Table.AddColumn(InsertShortYear, "FY", each "FY"&(if [MesAño]>=FYStartMonth then Text.From(Number.From([AñoCorto])+1) else [AñoCorto]))
		in
		    AddFY
		in
		    fnDateTable
		```
	lineageTag: 1fa255ab-dce8-4030-bd2f-1775534d629e

