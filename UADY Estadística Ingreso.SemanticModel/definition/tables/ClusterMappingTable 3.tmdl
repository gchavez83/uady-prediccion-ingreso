	partition 'ClusterMappingTable 3' = calculated
		mode: import
		source = ```
				VAR __DS0FilterTable = 
					TREATAS({"2024"}, 'Calendario'[Año])
				
				VAR __DS0Core = 
					SUMMARIZECOLUMNS(
						'Encabezado'[Programa de licenciatura],
						__DS0FilterTable,
						"Var___Punto_de_Corte", 'Metrics'[Var % Punto de Corte],
						"Var___Admitidos", 'Metrics'[Var % Admitidos]
					)
				
				VAR __DataTransformT0 = 
					KMeansClustering(
						SELECTCOLUMNS(
							__DS0Core,
							"Programa_de_licenciatura", 'Encabezado'[Programa de licenciatura],
							"Var___Punto_de_Corte", [Var___Punto_de_Corte],
							"Var___Admitidos", [Var___Admitidos]
						),
						{("[Programa_de_licenciatura]", "Item"),
							("[Var___Punto_de_Corte]", "Attribute"),
							("[Var___Admitidos]", "Attribute")},
						{("[Programa_de_licenciatura]", BLANK()),
							("ClusterId", "ClusterId")},
						5
					)
				
				RETURN __DataTransformT0
				```
			retainDataTillForceCalculate

	annotation ClusterMappingTable = true

