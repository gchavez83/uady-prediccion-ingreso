table Desconectada
	lineageTag: cf108ddf-0363-4c14-b52e-156f0726ab42

	measure 'Avg. Índice Ceneval Admitivo Licenciatura' = ```
			
			VAR X =
			    SELECTEDVALUE ( Desconectada[FOLIO CENEVAL] )
			VAR j =
			    LOOKUPVALUE ( Contenido[Name], Contenido[FOLIO CENEVAL], X )
			VAR i =
			    CALCULATE ( [Avg. Índice Ceneval Admitivo], Contenido[Name] = j )
			RETURN
			    i
			
			
			
			
			```
		formatString: #,0.0
		lineageTag: 38b3b0c0-a440-4c10-abdd-45129470c72d

		changedProperty = FormatString

