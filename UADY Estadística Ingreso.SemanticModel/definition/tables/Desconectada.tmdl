	measure 'Max Posición Corte' = ```
			
			MAXX (
			    FILTER (
			        Contenido,
			        Contenido[ESTATUS] = "Admitido"
			            && Contenido[Name] = [Name folio]
			    ),
			    Contenido[POSICIÓN]
			)
			
			
			```
		formatString: 0
