	measure 'Avg Total Admitidos OF' = ```
			
			AVERAGEX( 
			    SUMMARIZECOLUMNS( 
			        Consolidado_Reportes_Oficiales[Cluster Final Rename] , 
			        Consolidado_Reportes_Oficiales[Programas Educativos], 
			        "@Total_admitidos", [Total Admitidos OF] ) , [@Total_admitidos] )
			```
		formatString: 0.0
		lineageTag: 7a2ee4f9-3da5-41b3-8004-56ab8262ffd2

	measure 'Avg Sustentantes OF' = ```
			
			AVERAGEX (
			    ADDCOLUMNS (
			        SUMMARIZECOLUMNS (
			            Consolidado_Reportes_Oficiales[Cluster Final Rename],
			            Consolidado_Reportes_Oficiales[Programas Educativos]
			        ),
			        "@sustentantes_of", [Sustentantes OF]
			    ),
			    [@sustentantes_of]
			)
			
			```
		formatString: 0.0
		lineageTag: 19746d89-cff3-4c92-9fa5-6bcdaeec829d

