	measure 'Max Metric Years' = ```
			
			IF( NOT ISBLANK( [Metrics OF Dinámico] ), 
			MAXX( 
			    SUMMARIZE( ALLSELECTED( Consolidado_Reportes_Oficiales ) , 
			    Calendario[Año] , "@Metric" , [Metrics OF Dinámico] ), [@Metric] ) )
