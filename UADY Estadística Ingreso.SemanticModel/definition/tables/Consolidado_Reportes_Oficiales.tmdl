	/// Clusters for Programas Educativos
	column 'Programas Educativos (clusters)' = ```
			VAR __ClusterValue = 
				LOOKUPVALUE(
					'ClusterMappingTable 4'[ClusterId],
					'ClusterMappingTable 4'[Programas_Educativos],
					'Consolidado_Reportes_Oficiales'[Programas Educativos]
				)
			
			RETURN
				SWITCH(
					__ClusterValue,
					BLANK(),
					BLANK(),
					CONCATENATE("Cluster", __ClusterValue)
				)
			```
