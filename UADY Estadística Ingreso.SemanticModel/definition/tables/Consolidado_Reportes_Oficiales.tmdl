	measure 'Metrics OF LY Dinámico' = ```
			
			var _selector = SELECTEDVALUE( Metrics_OF[Value4])
			RETURN 
			SWITCH( TRUE() , 
			    _selector = "Sustentantes" , [Sustentantes OF LY] , 
			    _selector = "Admitidos", [Total Admitidos OF LY], 
			    _selector = "Avg Punto de Corte" , [Avg Punto de Corte OF LY] , 
			    _selector = "% Ingreso" , [% Ingreso OF LY],
			     _selector = "% Admitidos Cupo" , [% Admitidos OF Cupo LY])
			```
		lineageTag: bc250cf1-ccab-4878-a3df-ed423be02b21

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Titulo_1 = SELECTEDVALUE( Metrics_OF[Value4] ) & " vs Año Anterior por Campus y Programa de Licenciatura"
