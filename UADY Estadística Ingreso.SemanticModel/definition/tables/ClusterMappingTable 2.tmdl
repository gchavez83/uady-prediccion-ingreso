	partition 'ClusterMappingTable 2' = calculated
		mode: import
		source = ```
				VAR __DS0FilterTable = 
					TREATAS(
						{"'Metrics'[Avg. Índice Ceneval Admitivo]",
							"'Metrics'[Avg. Pensamiento Mat. Admitido]",
							"'Metrics'[Pct Ingreso]"},
						'Parameter'[Parameter Fields]
					)
				
				VAR __DS0FilterTable2 = 
					TREATAS({2024}, 'Encabezado'[Ciclo])
				
				VAR __DS0Core = 
					SUMMARIZECOLUMNS(
						'Encabezado'[Abv.1],
						__DS0FilterTable,
						__DS0FilterTable2,
						"Pct_Ingreso", 'Metrics'[Pct Ingreso],
						"Avg__punto_de_corte", 'Metrics'[Avg. punto de corte]
					)
				
				VAR __DataTransformT0 = 
					KMeansClustering(
						SELECTCOLUMNS(
							__DS0Core,
							"Abv_1", 'Encabezado'[Abv.1],
							"Pct_Ingreso", [Pct_Ingreso],
							"Avg__punto_de_corte", [Avg__punto_de_corte]
						),
						{("[Abv_1]", "Item"),
							("[Pct_Ingreso]", "Attribute"),
							("[Avg__punto_de_corte]", "Attribute")},
						{("[Abv_1]", BLANK()),
							("ClusterId", "ClusterId")},
						4
					)
				
				RETURN __DataTransformT0
				```
